# Signal Scout configuration. Copy to .env and edit. All values are optional.

# Port to expose on the host.
PORT=8000

# Shared password for the whole instance. Leave blank for open access.
SCOUT_PASSWORD=

# Anthropic API key for live content generation. If blank, Signal Scout falls
# back to structured templates (no LLM call). The key stays server-side.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# Optional: route LLM calls through a different Anthropic-compatible gateway
# (e.g. a Snowflake Cortex endpoint). "/v1/messages" is appended to the base URL.
# When ANTHROPIC_AUTH_TOKEN is set, it is sent as "Authorization: Bearer ..." in
# place of the x-api-key header. Leave both blank to use api.anthropic.com.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# Secret used to sign session cookies. Set a long random string to keep logins
# valid across restarts. If blank, a random key is generated per process.
SECRET_KEY=
